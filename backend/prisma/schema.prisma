generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Discussion {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  userId    String
  problemId String
  parentId  String?

  user      User     @relation(fields: [userId], references: [id])
  problem   Problem  @relation(fields: [problemId], references: [id])

  parent    Discussion? @relation("Thread", fields: [parentId], references: [id])
  replies   Discussion[] @relation("Thread")
}


model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String
  avatar      String?
  createdAt   DateTime     @default(now())
  role        Role         @default(USER)
  submissions Submission[]
  discussions Discussion[]
}

model Problem {
  id          String       @id @default(uuid())
  title       String
  description String
  difficulty  Difficulty
  tags        String[]     
  createdAt   DateTime     @default(now())
  submissions Submission[]
  testCases   TestCase[]
  discussions Discussion[]
}

model TestCase {
  id        String  @id @default(uuid())  
  input     String
  output    String
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id])
}

model Submission {
  id          String   @id @default(uuid())
  code        String
  verdict     Verdict
  runtimeMs   Int?
  userId      String
  problemId   String
  createdAt   DateTime @default(now())
  testResults Json?
  problem     Problem  @relation(fields: [problemId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Verdict {
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  PENDING
}

enum Role {
  USER
  ADMIN
}
